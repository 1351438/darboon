{
  "name": "darboon",
  "version": "0.0.1",
  "description": "Darboon — an open-source OAuth2/OIDC Identity Provider microservice (authentication + RBAC authorization).",
  "author": "Mohammad Nasher <nasher.themo@gmail.com>",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "start:dev": "pnpm --filter @darboon/idp start:dev",
    "start:prod": "pnpm --filter @darboon/idp start:prod"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "8.61.1"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/types": "8.61.1",
      "@typescript-eslint/tsconfig-utils": "8.61.1"
    }
  }
}
