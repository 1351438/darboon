# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Role this process runs as: 'api' (HTTP only), 'worker' (queues only), or 'all'
# (both — handy for local dev). docker-compose sets 'api'/'worker'.
DARBOON_ROLE=all

# ── Database ──────────────────────────────────────────────────────────────────
# localhost is for local dev (pnpm start:dev). Under docker-compose DATABASE_URL
# and REDIS_URL are overridden to the compose service names (postgres, redis).
DATABASE_URL=postgresql://darboon:secret@localhost:5432/darboon
POSTGRES_DB=darboon
POSTGRES_USER=darboon
POSTGRES_PASSWORD=secret
# Apply pending DB migrations on startup (enable on a single instance only).
RUN_MIGRATIONS=false

# ── Redis (BullMQ + throttler + RBAC cache) ───────────────────────────────────
REDIS_URL=redis://:secret@localhost:6379
REDIS_PASSWORD=secret

# ── Issuer / tokens ───────────────────────────────────────────────────────────
# Canonical issuer URL embedded as `iss` and used to build OIDC discovery.
DARBOON_ISSUER=http://localhost:3000
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
JWT_ALG=ES256
KEY_ROTATION_DAYS=90
# 32+ byte master key (AES-256-GCM) for encrypting signing private keys at rest.
# Generate: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=replace_with_a_32_byte_random_secret_value_here

# ── chapar notification gateway ───────────────────────────────────────────────
CHAPAR_BASE_URL=http://localhost:3000
# Plaintext API key sent to chapar as X-API-Key (chapar stores its SHA-256 hash).
CHAPAR_API_KEY=replace_with_chapar_api_key
OTP_APP_NAME=Darboon

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_WINDOW_SECONDS=60

# ── Google social login (optional in V1) ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# ── Password hashing (argon2id) ───────────────────────────────────────────────
ARGON_MEMORY_COST=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

# ── Account lockout ───────────────────────────────────────────────────────────
LOCKOUT_MAX_FAILURES=5
LOCKOUT_BASE_SECONDS=60

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Admin auth ────────────────────────────────────────────────────────────────
# SHA-256 (hex) of the admin API key for /admin + /oauth/introspect.
# Generate: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_KEY').digest('hex'))"
ADMIN_API_KEY_HASH=replace_with_sha256_hex_hash_of_your_admin_api_key
# Bootstrap admin user seeded on first start.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-immediately

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed dashboard origins. '*' allows any (dev only).
CORS_ALLOWED_ORIGINS=*
